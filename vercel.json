{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "digest.byjaden.com" }],
      "destination": "/digest.html"
    },
    {
      "source": "/news",
      "destination": "/news/index.html"
    },
    {
      "source": "/news/:slug",
      "destination": "/news/:slug.html"
    }
  ]
}